# builder runs for each target platform so OBITools4 binaries match the target architecture
# Uses the official golang image — no Go download needed inside the container
# Base image versions are substituted by the Makefile (GO_VERSION / ANACONDA_VERSION)
FROM golang:@@GO_VERSION@@ AS builder

ARG OBITOOLS_VERSION=latest
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update
RUN apt-get -y install \
    build-essential \
    ca-certificates \
    curl \
    make \
    unzip \
    zlib1g-dev

COPY docker/install_obitools.sh /tmp/install_obitools.sh
RUN if [ "$OBITOOLS_VERSION" = "latest" ]; then \
        bash /tmp/install_obitools.sh --install-dir /usr/local; \
    else \
        bash /tmp/install_obitools.sh --install-dir /usr/local --version "$OBITOOLS_VERSION"; \
    fi \
    && rm /tmp/install_obitools.sh

# Build C tools from src/
COPY src/ /tmp/src/
RUN for dir in /tmp/src/*/; do \
        dir="${dir%/}"; \
        if [ -f "$dir/Makefile" ]; then \
            make -C "$dir"; \
        fi; \
    done

FROM continuumio/miniconda3:@@ANACONDA_VERSION@@ AS skimindex

ARG KMINDEX_VERSION=bioconda::kmindex
ARG NTCARD_VERSION=bioconda::ntcard
ARG SRATOOLS_VERSION=bioconda::sra-tools
ARG OSSUUID_VERSION=conda-forge::ossuuid
ARG ASPERA_SDK_VERSION=1.1.7

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl make unzip less jq pigz sudo python3-plumbum \
    && rm -rf /var/lib/apt/lists/*

# Install NCBI datasets CLI tools from GitHub Releases (architecture-aware).
# Pin NCBI_DATASETS_VERSION to a specific tag (e.g. v18.21.0) for reproducible builds.
# Run `make update-ncbi-datasets` to update the pinned version.
ARG NCBI_DATASETS_VERSION=v18.21.0
ARG TARGETARCH
RUN mkdir -p /usr/local/bin \
    && curl -fsSL "https://github.com/ncbi/datasets/releases/download/${NCBI_DATASETS_VERSION}/linux-${TARGETARCH}.cli.package.zip" \
        -o /tmp/ncbi_datasets.zip \
    && unzip -o /tmp/ncbi_datasets.zip -d /usr/local/bin datasets dataformat \
    && chmod 755 /usr/local/bin/datasets /usr/local/bin/dataformat \
    && rm /tmp/ncbi_datasets.zip

RUN conda install --yes ${KMINDEX_VERSION} ${NTCARD_VERSION} ${OSSUUID_VERSION} ${SRATOOLS_VERSION} \
    && conda clean --all --yes

# Install IBM Aspera Transfer SDK (provides ascp) — architecture-aware.
# amd64 → linux-amd64 ; arm64 → linux-aarch64
# Pin ASPERA_SDK_VERSION for reproducible builds.
ARG ASPERA_SDK_VERSION=1.1.7
RUN case "${TARGETARCH}" in \
        amd64) _ascp_arch="amd64"   ;; \
        arm64) _ascp_arch="aarch64" ;; \
        *)     echo "Unsupported arch: ${TARGETARCH}" >&2; exit 1 ;; \
    esac \
    && _ascp_archive="ibm-aspera-transfer-sdk-linux-${_ascp_arch}-${ASPERA_SDK_VERSION}.tar.gz" \
    && curl -fsSL "https://d3pgwzphl5a0ty.cloudfront.net/${ASPERA_SDK_VERSION}/${_ascp_archive}" \
        | tar -xz -C /usr/local/bin \
            --strip-components=2 \
            "ibm-aspera-transfer-sdk-linux-${_ascp_arch}-${ASPERA_SDK_VERSION}/bin/ascp" \
    && chmod 755 /usr/local/bin/ascp \
    && vdb-config --restore-defaults || true \
    && vdb-config --set /TOOLS/ascp-path=/usr/local/bin/ascp || true

RUN mkdir -p /genbank \
             /indexes \
             /processed_data/decontamination \
             /processed_data/skims \
             /skims \
             /app/scripts /app/bin /app/obiluascripts \
             /config \
             /log


COPY --from=builder /usr/local/bin/obi* /usr/local/bin
COPY --from=builder /tmp/src/ /tmp/src-built/
COPY genbank/Makefile /genbank/Makefile
COPY obiluascripts/ /app/obiluascripts/
COPY scripts/ /app/scripts/
COPY config/ /config/
COPY src/skimindex_py/ /tmp/skimindex_py/

RUN chmod +x /usr/local/bin/obi* \
    && find /app/scripts -maxdepth 1 -name '*.sh' -exec chmod +x {} \; \
    && find /tmp/src-built -maxdepth 2 -type f -executable -exec cp {} /app/bin/ \; \
    && rm -rf /tmp/src-built \
    && pip install --no-build-isolation /tmp/skimindex_py \
    && rm -rf /tmp/skimindex_py

# Create an unprivileged user with a home directory and sudo access
RUN groupadd -r skimindex \
    && useradd -r -g skimindex \
               -m -d /home/skimindex \
               -s /bin/bash \
               skimindex \
    && echo "skimindex ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/skimindex \
    && chmod 0440 /etc/sudoers.d/skimindex

# OCI image annotations — declared here so they don't bust the build cache
ARG OCI_VERSION=latest
ARG OCI_CREATED
ARG OCI_REVISION

LABEL org.opencontainers.image.title="skimindex" \
      org.opencontainers.image.description="Genome skim kmer indexing." \
      org.opencontainers.image.url="https://registry.metabarcoding.org" \
      org.opencontainers.image.source="https://github.com/ArcEcoGen/skimindex" \
      org.opencontainers.image.vendor="Metabarcoding.org" \
      org.opencontainers.image.licenses="CECILL-2.1" \
      org.opencontainers.image.version="${OCI_VERSION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.revision="${OCI_REVISION}"

ENV PATH="/app/bin:/app/scripts:${PATH}"

WORKDIR /app

USER skimindex
